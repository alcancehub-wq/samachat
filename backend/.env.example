# WhatsApp Provider Configuration
# Supported providers: wwebjs, whaileys
WHATSAPP_PROVIDER=wwebjs

# Logging (silent, fatal, error, warn, info, debug, trace)
LOG_LEVEL=info
WHAILEYS_LOG_LEVEL=error

# Chrome/Puppeteer Configuration
CHROME_BIN=
CHROME_WS=
CHROME_ARGS=--no-sandbox --disable-setuid-sandbox

# Database
DB_HOST=mysql
DB_DIALECT=mysql
DB_PORT=3306
DB_NAME=whaticket
DB_USER=root
DB_PASS=senha

# JWT Secrets
JWT_SECRET=
JWT_REFRESH_SECRET=

# Backend URL
BACKEND_URL=https://api.DOMINIO.com

# Frontend URL
FRONTEND_URL=https://app.DOMINIO.com

# Proxy
PROXY_PORT=8080

# Redis
REDIS_URL=redis://redis:6379
REDIS_DB=0
