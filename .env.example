DATABASE_URL=postgresql://postgres:postgres@localhost:5432/samachat
WEB_PORT=3000
API_PORT=3001
PROVIDER_MODE=qr
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret
REDIS_URL=redis://127.0.0.1:6379
PROVIDER_SECRET=your-provider-secret
STORAGE_MODE=local
LOCAL_STORAGE_PATH=storage
LOG_LEVEL=info
RETRY_MAX_ATTEMPTS=3
RETRY_DELAY_MS=1000
TERMS_VERSION=2026-02-22
PRIVACY_VERSION=2026-02-22
WABA_VERIFY_TOKEN=your-verify-token
WABA_APP_SECRET=your-app-secret
WEBHOOK_MAX_PAYLOAD_BYTES=1048576
WEBHOOK_ALLOWED_CONTENT_TYPES=application/json
WEBHOOK_IDEMPOTENCY_TTL_SECONDS=3600
WEBHOOK_QR_SECRET=your-qr-secret
QUEUE_INBOUND_ATTEMPTS=5
QUEUE_INBOUND_BACKOFF_MS=2000
QUEUE_INBOUND_TIMEOUT_MS=30000
QUEUE_OUTBOUND_ATTEMPTS=5
QUEUE_OUTBOUND_BACKOFF_MS=2000
QUEUE_OUTBOUND_TIMEOUT_MS=30000
QUEUE_MEDIA_ATTEMPTS=5
QUEUE_MEDIA_BACKOFF_MS=2000
QUEUE_MEDIA_TIMEOUT_MS=30000
