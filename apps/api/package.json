{
  "name": "@samachat/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "pnpm --filter @samachat/shared --filter @samachat/config --filter @samachat/logger --filter @samachat/messaging --filter @samachat/storage --filter @samachat/db build",
    "prebuild": "pnpm --filter @samachat/shared --filter @samachat/config --filter @samachat/logger --filter @samachat/messaging --filter @samachat/storage --filter @samachat/db build",
    "dev": "dotenv -e .env.local -- nest start --watch",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/auto-instrumentations-node": "^0.51.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.51.0",
    "@opentelemetry/resources": "^1.25.0",
    "@opentelemetry/sdk-node": "^0.51.0",
    "@opentelemetry/sdk-trace-base": "^1.25.0",
    "@opentelemetry/semantic-conventions": "^1.25.0",
    "@nestjs/common": "^10.4.9",
    "@nestjs/core": "^10.4.9",
    "@nestjs/platform-express": "^10.4.9",
    "@nestjs/throttler": "^5.2.1",
    "@nestjs/swagger": "^7.4.2",
    "@prisma/client": "^6.1.0",
    "@samachat/config": "workspace:*",
    "@samachat/logger": "workspace:*",
    "@samachat/messaging": "workspace:*",
    "@samachat/shared": "workspace:*",
    "bullmq": "^5.15.0",
    "express": "^4.21.2",
    "ioredis": "5.9.3",
    "jsonwebtoken": "^9.0.2",
    "prom-client": "^15.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.2",
    "@nestjs/testing": "^10.4.9",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.17.16",
    "@types/supertest": "^2.0.16",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2"
  }
}
