REDIS_URL=redis://127.0.0.1:6379
PROVIDER_MODE=qr
LOG_LEVEL=info
RETRY_MAX_ATTEMPTS=3
RETRY_DELAY_MS=1000
QUEUE_INBOUND_ATTEMPTS=5
QUEUE_INBOUND_BACKOFF_MS=2000
QUEUE_INBOUND_TIMEOUT_MS=30000
QUEUE_OUTBOUND_ATTEMPTS=5
QUEUE_OUTBOUND_BACKOFF_MS=2000
QUEUE_OUTBOUND_TIMEOUT_MS=30000
QUEUE_MEDIA_ATTEMPTS=5
QUEUE_MEDIA_BACKOFF_MS=2000
QUEUE_MEDIA_TIMEOUT_MS=30000
QUEUE_DLQ_TIMEOUT_MS=30000
